<UserControl x:Class="Pokladna.Ribbon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Pokladna"
             xmlns:ribbon="clr-namespace:System.Windows.Controls.Ribbon;assembly=System.Windows.Controls.Ribbon"
             mc:Ignorable="d" >
    <Grid>
        <Ribbon SelectedIndex="0" x:Name="MainRibbon">
            <Ribbon.ApplicationMenu>
                <RibbonApplicationMenu>
                    <RibbonApplicationMenuItem Header="Konec"/>
                </RibbonApplicationMenu>
            </Ribbon.ApplicationMenu>
            <RibbonTab Header="Domů" x:Name="TabHome">
                <RibbonGroup Header="Hlavní">
                    <RibbonButton Label="Ceník" LargeImageSource="pack://application:,,,/Pokladna;component/Resources/configure.png" />
                    <RibbonButton Label="Zaměstnanci" LargeImageSource="pack://application:,,,/Pokladna;component/Resources/user.png" />
                    <RibbonButton Label="Dárkové karty" LargeImageSource="pack://application:,,,/Pokladna;component/Resources/configure.png" />
                    <RibbonButton Label="Kupony" LargeImageSource="pack://application:,,,/Pokladna;component/Resources/configure.png" />
                </RibbonGroup>
                <RibbonGroup Header="Výstupy">
                    <RibbonButton Label="Transakce" LargeImageSource="pack://application:,,,/Pokladna;component/Resources/configure.png" />
                    <RibbonButton Label="Prodeje položek" LargeImageSource="pack://application:,,,/Pokladna;component/Resources/configure.png" />
                </RibbonGroup>
                <RibbonGroup Header="Nastavení">
                    <RibbonButton Label="Nastavení" LargeImageSource="pack://application:,,,/Pokladna;component/Resources/configure.png" ToolTipDescription="Nastavení parametrů systému" />
                </RibbonGroup>
                <RibbonGroup></RibbonGroup>
            </RibbonTab>
            <RibbonTab Header="Ceník" x:Name="TabPriceList">
                <RibbonGroup Header="Ceník">
                    <RibbonButton Label="Upravit položku" LargeImageSource="pack://application:,,,/Pokladna;component/Resources/pencil.png" />
                    <RibbonButton Label="Přecenění položek" LargeImageSource="pack://application:,,,/Pokladna;component/Resources/exit.png" />
                </RibbonGroup>
                <RibbonGroup Header="Konec">
                    <RibbonButton Label="Konec" LargeImageSource="pack://application:,,,/Pokladna;component/Resources/exit.png" ToolTipDescription="Zavřít aktuální okno" />
                </RibbonGroup>
            </RibbonTab>
            <RibbonTab Header="Dárkové karty" x:Name="TabGiftCards">
                <RibbonGroup Header="Záznam">
                    <RibbonButton Label="Přidat" LargeImageSource="pack://application:,,,/Pokladna;component/Resources/document-new.png" />
                    <RibbonButton Label="Upravit" LargeImageSource="pack://application:,,,/Pokladna;component/Resources/document-edit.png" />
                    <RibbonButton Label="Odstranit" LargeImageSource="pack://application:,,,/Pokladna;component/Resources/document-close.png" />
                </RibbonGroup>
                <RibbonGroup Header="Úpravy">
                    <RibbonButton Label="Vymazat neplatné" LargeImageSource="pack://application:,,,/Pokladna;component/Resources/exit.png"/>
                </RibbonGroup>
                <RibbonGroup Header="Export">
                    <RibbonButton Label="PDF" LargeImageSource="pack://application:,,,/Pokladna;component/Resources/user-new.png"/>
                    <RibbonButton Label="Excel" LargeImageSource="pack://application:,,,/Pokladna;component/Resources/user-new.png"/>
                    <RibbonButton Label="CSV" LargeImageSource="pack://application:,,,/Pokladna;component/Resources/user-new.png"/>
                </RibbonGroup>
                <RibbonGroup Header="Konec">
                    <RibbonButton Label="Konec" LargeImageSource="pack://application:,,,/Pokladna;component/Resources/exit.png" />
                </RibbonGroup>
            </RibbonTab>
            <RibbonTab Header="Kupony" x:Name="TabCoupons">
                <RibbonGroup Header="Záznam">
                    <RibbonButton Label="Přidat" LargeImageSource="pack://application:,,,/Pokladna;component/Resources/document-new.png" />
                    <RibbonButton Label="Upravit" LargeImageSource="pack://application:,,,/Pokladna;component/Resources/document-edit.png" />
                    <RibbonButton Label="Odstranit" LargeImageSource="pack://application:,,,/Pokladna;component/Resources/document-close.png" />
                </RibbonGroup>
                <RibbonGroup Header="Úpravy">
                    <RibbonButton Label="Vymazat neplatné" LargeImageSource="pack://application:,,,/Pokladna;component/Resources/exit.png"/>
                </RibbonGroup>
                <RibbonGroup Header="Export">
                    <RibbonButton Label="PDF" LargeImageSource="pack://application:,,,/Pokladna;component/Resources/user-new.png"/>
                    <RibbonButton Label="Excel" LargeImageSource="pack://application:,,,/Pokladna;component/Resources/user-new.png"/>
                    <RibbonButton Label="CSV" LargeImageSource="pack://application:,,,/Pokladna;component/Resources/user-new.png"/>
                </RibbonGroup>
                <RibbonGroup Header="Konec">
                    <RibbonButton Label="Konec" LargeImageSource="pack://application:,,,/Pokladna;component/Resources/exit.png" />
                </RibbonGroup>
            </RibbonTab>
            <RibbonTab Header="Zaměstnanci" x:Name="TabEmployees">
                <RibbonGroup Header="Zaměstnanec">
                    <RibbonButton Label="Přidat" LargeImageSource="pack://application:,,,/Pokladna;component/Resources/user-new.png" />
                    <RibbonButton Label="Upravit" LargeImageSource="pack://application:,,,/Pokladna;component/Resources/user-properties.png" />
                    <RibbonButton Label="Odstranit" LargeImageSource="pack://application:,,,/Pokladna;component/Resources/user-delete.png" />
                </RibbonGroup>
                <RibbonGroup Header="Konec">
                    <RibbonButton Label="Konec" LargeImageSource="pack://application:,,,/Pokladna;component/Resources/exit.png" />
                </RibbonGroup>
            </RibbonTab>
            <RibbonTab Header="Výpisy" x:Name="TabOutputs">
                <RibbonGroup Header="Úpravy">
                    <RibbonButton Label="Vymazat" LargeImageSource="pack://application:,,,/Pokladna;component/Resources/user-new.png"/>
                </RibbonGroup>
                <RibbonGroup Header="Nástroje">
                    <RibbonButton Label="Řazení" LargeImageSource="pack://application:,,,/Pokladna;component/Resources/user-new.png"/>
                    <RibbonButton Label="Filtr" LargeImageSource="pack://application:,,,/Pokladna;component/Resources/user-new.png"/>
                </RibbonGroup>
                <RibbonGroup Header="Export">
                    <RibbonButton Label="PDF"  LargeImageSource="pack://application:,,,/Pokladna;component/Resources/user-new.png"/>
                    <RibbonButton Label="Excel"  LargeImageSource="pack://application:,,,/Pokladna;component/Resources/user-new.png"/>
                    <RibbonButton Label="CSV"  LargeImageSource="pack://application:,,,/Pokladna;component/Resources/user-new.png"/>
                </RibbonGroup>
                <RibbonGroup Header="Konec">
                    <RibbonButton Label="Konec"  LargeImageSource="pack://application:,,,/Pokladna;component/Resources/exit.png" />
                </RibbonGroup>
            </RibbonTab>
        </Ribbon>
    </Grid>
</UserControl>
